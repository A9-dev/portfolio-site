<nav class="flex justify-center items-center w-full p-8">
  <a href="/" class="relative px-2 group">
    <span
      class="transition-colors duration-300 group-hover:text-blue-500 dark:group-hover:text-blue-300"
      >Home</span
    >
  </a>
  <a href="/projects" class="relative px-2 group">
    <span
      class="transition-colors duration-300 group-hover:text-blue-500 dark:group-hover:text-blue-300"
      >Projects</span
    >
  </a>
  <a href="/progression-log" class="relative px-2 group">
    <span
      class="transition-colors duration-300 group-hover:text-blue-500 dark:group-hover:text-blue-300"
      >Progression Log</span
    >
  </a>
  <button
    id="theme-toggle"
    aria-label="Toggle dark mode"
    class="ml-2 p-2 rounded-full transition-colors duration-200 hover:bg-neutral-300 dark:hover:bg-neutral-700 cursor-pointer"
  >
    <span class="relative block w-5 h-5">
      <!-- Sun icon: visible in light mode -->
      <svg
        class="sun-icon absolute inset-0 w-5 h-5"
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <circle cx="12" cy="12" r="4"></circle>
        <line x1="12" y1="2" x2="12" y2="4"></line>
        <line x1="12" y1="20" x2="12" y2="22"></line>
        <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
        <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
        <line x1="2" y1="12" x2="4" y2="12"></line>
        <line x1="20" y1="12" x2="22" y2="12"></line>
        <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
        <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
      </svg>
      <!-- Moon icon: visible in dark mode -->
      <svg
        class="moon-icon absolute inset-0 w-5 h-5"
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
      </svg>
    </span>
  </button>
</nav>

<style>
  .sun-icon,
  .moon-icon {
    transition:
      transform 0.3s ease,
      opacity 0.3s ease;
  }

  .sun-icon {
    opacity: 1;
    transform: rotate(0deg) scale(1);
  }

  .moon-icon {
    opacity: 0;
    transform: rotate(90deg) scale(0.5);
  }

  :global(html.dark) .sun-icon {
    opacity: 0;
    transform: rotate(-90deg) scale(0.5);
  }

  :global(html.dark) .moon-icon {
    opacity: 1;
    transform: rotate(0deg) scale(1);
  }
</style>

<script>
  function setupThemeToggle() {
    const btn = document.getElementById("theme-toggle");
    if (!btn) return;
    btn.addEventListener("click", () => {
      const isDark = document.documentElement.classList.toggle("dark");
      localStorage.setItem("theme", isDark ? "dark" : "light");
    });
  }

  setupThemeToggle();
  document.addEventListener("astro:after-swap", setupThemeToggle);
</script>
