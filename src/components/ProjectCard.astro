---
import type { CollectionEntry } from "astro:content";

interface Props {
  project: CollectionEntry<"projects">;
}

const { project } = Astro.props;
---

<article
  class="h-full overflow-hidden rounded-2xl border border-neutral-200/80 bg-white/70 shadow-sm transition-all duration-200 hover:-translate-y-1 hover:border-neutral-300 dark:border-neutral-700/80 dark:bg-neutral-900/60 dark:hover:border-neutral-600"
>
  {
    project.data.coverImage ? (
      <img
        src={project.data.coverImage}
        alt={`${project.data.title} cover image`}
        class="h-52 w-full object-cover"
        loading="lazy"
      />
    ) : (
      <div
        class="h-52 w-full bg-neutral-200 dark:bg-neutral-800"
        aria-hidden="true"
      />
    )
  }

  <div class="flex h-[calc(100%-13rem)] flex-col gap-4 p-6">
    <div class="flex items-start justify-between gap-4">
      <div class="space-y-2">
        <h2 class="text-2xl font-bold text-neutral-950 dark:text-neutral-50">
          {project.data.title}
        </h2>
        <time
          datetime={project.data.publishedAt.toISOString()}
          class="text-sm text-neutral-500 dark:text-neutral-400"
        >
          {project.data.publishedAt.toLocaleDateString()}
        </time>
      </div>
      {
        project.data.featured && (
          <span class="shrink-0 rounded-full bg-blue-100 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-blue-700 dark:bg-blue-500/15 dark:text-blue-300">
            Featured
          </span>
        )
      }
    </div>

    <p class="text-pretty text-neutral-700 dark:text-neutral-300">
      {project.data.summary}
    </p>

    {
      project.data.tags.length > 0 && (
        <ul class="mt-auto flex flex-wrap gap-2">
          {project.data.tags.map((tag) => (
            <li class="rounded-full bg-neutral-200/70 px-3 py-1 text-sm text-neutral-700 dark:bg-neutral-800 dark:text-neutral-300">
              {tag}
            </li>
          ))}
        </ul>
      )
    }
  </div>
</article>
