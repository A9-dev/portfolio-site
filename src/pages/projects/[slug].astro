---
import { getCollection, render, type CollectionEntry } from "astro:content";
import BaseLayout from "../../components/BaseLayout.astro";
import Title from "../../components/Title.astro";

export async function getStaticPaths() {
  const projects = await getCollection(
    "projects",
    ({ data }) => data.published,
  );

  return projects.map((project) => ({
    params: { slug: project.data.slug },
    props: { project },
  }));
}

const { project }: { project: CollectionEntry<"projects"> } = Astro.props;
const { Content } = await render(project);
const pageTitle = project.data.seo?.title ?? project.data.title;
---

<BaseLayout title={pageTitle}>
  <article class="mx-auto flex w-full max-w-4xl flex-col gap-y-8 px-4">
    <header class="flex flex-col gap-y-5">
      <a
        href="/projects"
        class="w-fit text-sm font-semibold uppercase tracking-wide text-blue-700 transition-colors duration-200 hover:text-blue-500 dark:text-blue-300 dark:hover:text-blue-200"
      >
        Projects
      </a>

      <div class="space-y-4">
        <time
          datetime={project.data.publishedAt.toISOString()}
          class="block text-sm text-neutral-500 dark:text-neutral-400"
        >
          {project.data.publishedAt.toLocaleDateString()}
        </time>
        <Title class="mb-0 text-balance">{project.data.title}</Title>
        <p class="max-w-3xl text-xl text-neutral-600 dark:text-neutral-300">
          {project.data.summary}
        </p>
        {
          project.data.tags.length > 0 && (
            <ul class="flex flex-wrap gap-2">
              {project.data.tags.map((tag) => (
                <li class="rounded-full bg-neutral-200/70 px-3 py-1 text-sm text-neutral-700 dark:bg-neutral-800 dark:text-neutral-300">
                  {tag}
                </li>
              ))}
            </ul>
          )
        }
      </div>
    </header>

    <div class="prose prose-lg max-w-none dark:prose-invert">
      <Content />
    </div>
  </article>
</BaseLayout>
